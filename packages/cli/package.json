{
  "name": "@isarai/maestro",
  "version": "0.1.15",
  "description": "Standalone CLI for running the Maestro server",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olsommer/maestro.git"
  },
  "homepage": "https://github.com/olsommer/maestro",
