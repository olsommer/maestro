    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.0.0",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "socket.io": "^4.8.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^3.24.0"
