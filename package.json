{
  "name": "maestro",
  "private": true,
  "bin": {
    "maestro": "./bin/maestro.js"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "maestro": "node ./bin/maestro.js",
    "dev:server": "pnpm --filter @maestro/server dev",
    "dev:client": "pnpm --filter @maestro/client dev",
    "build": "pnpm -r run build"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
